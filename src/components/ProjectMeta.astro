---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../lib/i18n';
import { t } from '../lib/i18n';
import { getLocalized } from '../lib/projects';
import { getRoleBySlug } from '../lib/roles';

interface Props {
  project: CollectionEntry<'projects'>;
  locale: Locale;
}

const { project, locale } = Astro.props;
const p = project.data;
const teammembers = p.teammembers ?? [];
---

<div id="projMeta">
  <div class="projMetaItem">
    <h2>{t('type', locale)}</h2>
    <p>{getLocalized(p.projectType, locale)}</p>
  </div>
  <div class="projMetaItem">
    <h2>{t('year', locale)}</h2>
    <p>{p.year}</p>
  </div>
  <div class="projMetaItem skillsApplied">
    <h2>{t('skills_applied', locale)}</h2>
    <ul>
      {p.roles.map((slug) => {
        const role = getRoleBySlug(slug);
        return <li>{role ? (locale === 'de' ? role.name.de : role.name.en) : slug}</li>;
      })}
    </ul>
  </div>
  <div class="projMetaItem team">
    {!p.company ? (
      <>
        <h2>{t('team', locale)}</h2>
        <ul>
          {teammembers.length === 0 ? <li>{t('personal_project', locale)}</li> : null}
          {teammembers.map((member) => <li>{member}</li>)}
        </ul>
      </>
    ) : (
      <>
        <h2>{t('company', locale)}</h2>
        <a href="https://clir.io/" target="_blank" rel="noopener noreferrer">{p.company}</a>
      </>
    )}
  </div>
</div>
