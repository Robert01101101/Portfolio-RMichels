---
import type { Locale } from '../lib/i18n';
import { getLocalized } from '../lib/projects';
import type { CollectionEntry } from 'astro:content';

interface Props {
  slug: string;
  name: string;
  type: string;
  inDevelopment?: boolean;
  roles?: string[];
  locale: Locale;
  href?: string;
}

const { slug, name, type, inDevelopment = false, roles = [], locale, href } = Astro.props;
const prefix = locale === 'de' ? '/de' : '';
const finalHref = href ?? `${prefix}${inDevelopment ? `/development/${slug}` : `/${slug}`}`;
const roleString = roles.join(',');
---

<div class="projRow projRow--visible" data-js={roleString || undefined}>
  <div class:list={['projPanel', inDevelopment && 'inDevelopment']}>
    <a href={finalHref} title={name}>
      <img
        src={`/assets/img/lqip/${slug}.jpg`}
        loading="lazy"
        alt={name}
        class:list={inDevelopment ? ['inDevelopment'] : undefined}
      />
      {inDevelopment && <div class="inDevelopmentText">{locale === 'de' ? 'In Entwicklung' : 'In Development'}</div>}
      <div class="projJScontainer">
        <h2 class="projLabel">{name}</h2>
        <h3 class="projMeta">{type}</h3>
      </div>
    </a>
  </div>
</div>
