---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../lib/i18n';
import { heroLqipExists } from '../lib/assets';
import { getLocalized, getProjectSlug } from '../lib/projects';
import Icon from './Icon.astro';

interface Props {
  project: CollectionEntry<'projects'> | CollectionEntry<'projects-de'>;
  locale: Locale;
}

const { project, locale } = Astro.props;
const p = project.data;
const slug = getProjectSlug(project);
const links = p.links ?? [];
const hasHeroLqip = heroLqipExists(slug);
const heroSrc = `/assets/img/${slug}.jpg`;
const heroName = getLocalized(p.name, locale);
---

<div class="projectDownArrowWrapper">
  <div class="downArrow downArrow-project" id="downArrow">
    <a href="#projMeta"><Icon name="chevron-down" class="icon-chevron-down" /></a>
  </div>
</div>
<div id="projLanding">
  <div class="row">
    <div class="col-50">
      <div class="landingText">
        <h1>{heroName}</h1>
        <p>{getLocalized(p.description, locale)}</p>
        <br />
        <div class="projectCallToAction">
          {links.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
    </div>
    <div class="col-50">
      {hasHeroLqip && (
        <img
          src={`/assets/img/lqip/${slug}.jpg`}
          class:list={['imgBG', p.heroAltLayout && 'alt']}
          alt=""
          aria-hidden="true"
          lqip-ignore
          width="800"
          height="600"
          decoding="async"
        />
      )}
      <img
        src={heroSrc}
        alt={heroName}
        class="heroImg"
        fetchpriority="high"
        loading="eager"
        decoding="async"
        width="800"
        height="600"
      />
    </div>
  </div>
</div>
