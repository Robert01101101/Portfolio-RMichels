---
import { t, type Locale } from '../lib/i18n';
import Icon from './Icon.astro';

interface Props {
  locale: Locale;
  pageType?: 'home' | 'about' | 'projects' | 'project' | 'privacy' | 'default';
}

const { locale, pageType = 'default' } = Astro.props;
const showContact = pageType !== 'about';

const resumeFile =
  locale === 'de'
    ? '/assets/other/RobertMichelsLebenslauf.pdf'
    : '/assets/other/RobertMichelsResume.pdf';
const privacyHref = locale === 'de' ? '/de/privacyPolicy' : '/privacyPolicy';
const portfolioHref = locale === 'de' ? '/de/portfolio' : '/portfolio';
const year = new Date().getFullYear();
---

<footer id="Contact">
  {showContact && (
    <div>
      <ul class="icons">
        <div class="emailContainer">
          <a href="mailto: hi@rmichels.com" target="_blank" title="E-Mail | Right-click to copy to clipboard" id="emailLink">
            <li><Icon name="envelope" size="2x" id="email" /></li>
          </a>
        </div>
        <small class="js-emaillink">hi@rmichels.com</small>
        <a href="https://linkedin.com/in/robert-michels" target="_blank" title="LinkedIn"><li><Icon name="linkedin-in" size="2x" /></li></a>
        <a href="https://github.com/Robert01101101" target="_blank" title="GitHub"><li><Icon name="github" size="2x" /></li></a>
        <a href="https://play.google.com/store/apps/developer?id=Studio+RM" target="_blank" title="Google Play"><li><Icon name="google-play" size="2x" /></li></a>
        <a href="https://rmichels.itch.io/" target="_blank"><li><Icon name="itch-io" size="2x" /></li></a>
      </ul>
    </div>
  )}
  {showContact && <noscript><small>hi@rmichels.com</small></noscript>}
  <div class="footerEnd">
    <small>
      {t('portfolio_developed', locale)}
      <a href={portfolioHref}>{t('developed', locale)}</a>
      {t('with_astro', locale)}
    </small>
    <small>{t('copyright', locale)} &copy; {year} {t('rights_reserved', locale)}</small>
    <label class="toggle-label">
      <input type="checkbox" id="lenisScrollToggle" checked />
      <small>{t('enable_smooth_scrolling', locale)}</small>
    </label>
    <div>
      {showContact && <a href={resumeFile}><small>{t('resume', locale)}</small></a>}
      <a href={privacyHref}><small>{t('privacy_policy', locale)}</small></a>
    </div>
  </div>
</footer>
<div class="footerBuffer"></div>

<div id="copyConfirm" class="hidden"><small>{t('copied', locale)}</small></div>

<div id="imageViewer" class="hidden">
  <a class="prev">&#10094;</a>
  <a class="next">&#10095;</a>
  <a class="closeBtn">&#10006;</a>
  <Icon name="expand" class="viewer-control-icon hidden" id="fullScreenExpand" />
  <Icon name="compress" class="viewer-control-icon" id="fullScreenCompress" />
</div>

<script>
  import '../islands/Lqip.ts';
</script>
<script>
  import '../islands/EmailCopy.ts';
</script>
