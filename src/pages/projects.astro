---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectTile from '../components/ProjectTile.astro';
import { roles } from '../lib/roles';
import { getAllProjects, projectToTileData } from '../lib/projects';
import { t } from '../lib/i18n';

const locale = 'en' as const;
const projects = await getAllProjects();
const title = 'All Projects | Robert Michels Portfolio';
const description = 'Browse through all my projects. Filter them to only see relevant projects. | Robert Michels Portfolio';
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  pageType="projects"
  canonicalPath="/projects"
>
  <section id="Projects">
    <div class="projectsFilter">
      <div>
        <h1>{t('filter_projects', locale)} (<span id="projectCount">{projects.length}</span>)</h1>
      </div>
      {roles.map((role) => (
        <button class="filterBtn" data-js={role.slug}>{role.name.en}</button>
      ))}
    </div>
    <div id="projectTileHidden"></div>
    <div id="projectTileVisible">
      {projects.map((project) => {
        const tile = projectToTileData(project, locale);
        return (
          <ProjectTile slug={tile.slug} name={tile.name} type={tile.type} inDevelopment={tile.inDevelopment} roles={tile.roles} locale={locale} />
        );
      })}
    </div>
  </section>
</BaseLayout>
