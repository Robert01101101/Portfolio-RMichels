---
import { getCollection } from 'astro:content';
import ProjectLayout from '../../../layouts/ProjectLayout.astro';
import ProjectContent from '../../../components/ProjectContent.astro';
import { getProjectSlug } from '../../../lib/projects';

export async function getStaticPaths() {
  const projects = await getCollection(
    'projects-de',
    ({ data }) => !data.draft && data.inDevelopment,
  );
  return projects.map((project) => ({
    params: { slug: getProjectSlug(project) },
    props: { project },
  }));
}

const { project } = Astro.props;
const locale = 'de' as const;
---

<ProjectLayout project={project} locale={locale}>
  <ProjectContent project={project} locale={locale} />
</ProjectLayout>
