---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectTile from '../../components/ProjectTile.astro';
import Icon from '../../components/Icon.astro';
import { getAllProjects, projectToTileData } from '../../lib/projects';
import { t } from '../../lib/i18n';

const locale = 'de' as const;
const params = Astro.url.searchParams;
const greeting = params.get('greeting');
const allProjects = await getAllProjects(locale);
const textRotateItems = t('text_rotate', locale).split('", "').map((s) => s.replace(/^"|"$/g, ''));
const title = 'Portfolio | Robert Michels';
const description = 'Robert Michels — Designer und Entwickler aus Vancouver.';
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  pageType="home"
  canonicalPath="/de/"
>
  <div class="downArrowWrapper">
    <div class="downArrow" id="downArrow">
      <a href="#MyWork" title={t('view_projects', locale)}><Icon name="chevron-down" class="icon-chevron-down" /></a>
    </div>
  </div>
  <div id="threeModel" style="visibility: hidden; display: none;"></div>
  <div class="landingModelImageWrapper">
    <img src="/assets/img/landingModel.webp" id="landingModelImage" alt="" />
    <div id="spinner" class="landingSpinner" style="display: none;">
      <div class="fancySpinner"></div>
    </div>
  </div>
  <div id="landingArea">
    <div class="row">
      <div class="col-50" id="landingText">
        <p>
          {greeting ? (
            <>
              {t('hi_greeting', locale)}{greeting},
              <br />
              {t('greeting_suffix', locale).replace(/^, /, '')}
            </>
          ) : (
            <span set:html={t('hi_im_robert', locale).replace('Robert Michels', 'Robert&nbsp;Michels')} />
          )}
          <br />{t('i_design', locale)}<br />
          <span class="txt-rotate" data-period="2000" data-rotate={JSON.stringify(textRotateItems)}>
            {t('digital_media', locale)}
          </span>
        </p>
      </div>
    </div>
  </div>
  <section class="sectionMedia" id="MyWork">
    {allProjects.map((project) => {
      const tile = projectToTileData(project, locale);
      return (
        <ProjectTile
          slug={tile.slug}
          name={tile.name}
          type={tile.type}
          inDevelopment={tile.inDevelopment}
          roles={tile.roles}
          locale={locale}
        />
      );
    })}
    <div class="seeMoreBtn">
      <a href="/de/projects" title="See More">
        <span>{t('see_more', locale)}</span>
        <div class="liquid"></div>
      </a>
    </div>
  </section>
  <script>
    import '../../islands/HomeFilter.ts';
  </script>
</BaseLayout>
