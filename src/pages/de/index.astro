---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectTile from '../../components/ProjectTile.astro';
import { getAllProjects, filterByRoles, projectToTileData } from '../../lib/projects';
import { t } from '../../lib/i18n';

const locale = 'de' as const;
const params = Astro.url.searchParams;
const filterParam = params.get('filter');
const filters = filterParam ? filterParam.split(',').filter(Boolean) : [];
const allProjects = await getAllProjects();
let projects = filters.length ? filterByRoles(allProjects, filters) : allProjects.slice(0, 6);
if (filters.length && !projects.length) projects = allProjects.slice(0, 5);
const greeting = params.get('greeting');
const textRotateItems = ['Full-Stack-Apps.', 'Spiele.', 'VR-Erlebnisse.', 'Mobile Apps.', 'Websites.'];
---

<BaseLayout
  title="Portfolio | Robert Michels"
  description="Robert Michels — Designer und Entwickler aus Vancouver."
  locale={locale}
  pageType="home"
  canonicalPath="/de/"
>
  <div class="downArrowWrapper">
    <div class="downArrow" id="downArrow">
      <a href="#MyWork" title="View Projects"><i class="fa-solid fa-chevron-down"></i></a>
    </div>
  </div>
  <canvas id="threeModel" style="visibility: hidden; display: none;"></canvas>
  <div class="landingModelImageWrapper">
    <img src="/assets/img/landingModel.webp" id="landingModelImage" alt="" />
    <div id="spinner" class="landingSpinner" style="display: none;">
      <div class="fancySpinner"></div>
    </div>
  </div>
  <div id="landingArea">
    <div class="row">
      <div class="col-50" id="landingText">
        <p>
          {greeting ? (
            <>Hallo {greeting},<br />ich bin Robert Michels.</>
          ) : (
            <>Hallo, ich bin Robert&nbsp;Michels.</>
          )}
          <br />Ich designe und programmiere<br />
          <span class="txt-rotate" data-period="2000" data-rotate={JSON.stringify(textRotateItems)}>
            digitale Medien.
          </span>
        </p>
      </div>
    </div>
  </div>
  <section class="sectionMedia" id="MyWork">
    {projects.map((project) => {
      const tile = projectToTileData(project, locale);
      return (
        <ProjectTile
          slug={tile.slug}
          name={tile.name}
          type={tile.type}
          inDevelopment={tile.inDevelopment}
          roles={tile.roles}
          locale={locale}
        />
      );
    })}
    <div class="seeMoreBtn">
      <a href="/de/projects" title="See More">
        <span>{t('see_more', locale)}</span>
        <div class="liquid"></div>
      </a>
    </div>
  </section>
  {filterParam && filters.length > 0 && projects.length > 0 && (
    <script is:inline define:vars={{ filterParam }}>
      document.cookie = `visitorFilter=${encodeURIComponent(filterParam)}; path=/; max-age=31536000`;
    </script>
  )}
  {!filterParam && (
    <script is:inline>
      document.cookie = 'visitorFilter=; Max-Age=0; path=/';
    </script>
  )}
</BaseLayout>
