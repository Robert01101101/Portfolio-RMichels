---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectTile from '../../components/ProjectTile.astro';
import { roles } from '../../lib/roles';
import { getAllProjects, projectToTileData } from '../../lib/projects';
import { t } from '../../lib/i18n';

const locale = 'de' as const;
const projects = await getAllProjects(locale);
---

<BaseLayout
  title="Alle Projekte | Robert Michels Portfolio"
  description="Durchsuche alle meine Projekte. Filtere sie, um nur relevante Projekte zu sehen."
  locale={locale}
  pageType="projects"
  canonicalPath="/de/projects"
>
  <section id="Projects">
    <div class="projectsFilter">
      <div>
        <h1>{t('filter_projects', locale)} (<span id="projectCount">{projects.length}</span>)</h1>
      </div>
      {roles.map((role) => (
        <button class="filterBtn" data-js={role.slug}>{role.name.de}</button>
      ))}
    </div>
    <div id="projectTileHidden"></div>
    <div id="projectTileVisible">
      {projects.map((project) => {
        const tile = projectToTileData(project, locale);
        return (
          <ProjectTile slug={tile.slug} name={tile.name} type={tile.type} inDevelopment={tile.inDevelopment} roles={tile.roles} locale={locale} />
        );
      })}
    </div>
  </section>
</BaseLayout>
