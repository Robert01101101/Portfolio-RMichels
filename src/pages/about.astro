---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutContact from '../components/AboutContact.astro';
import AboutMain from '../components/AboutMain.astro';
import AboutSkills from '../components/AboutSkills.astro';
import { t } from '../lib/i18n';

const locale = 'en' as const;
---

<BaseLayout
  title="About | Robert Michels Portfolio"
  description="Who is this Robert Michels? I'm a digital media designer and developer from Vancouver."
  locale={locale}
  pageType="about"
  canonicalPath="/about"
>
  <section class="sectionText about">
    <div>
      <img src="/assets/img/portrait.jpg" alt="Robert Michels" />
    </div>
    <AboutMain locale={locale} />
    <div class="aboutAside">
      <h2>{t('skills', locale)}</h2>
      <AboutSkills locale={locale} />
      <h2 class="aboutSayHi-heading">{t('say_hi_heading', locale)}</h2>
      <AboutContact />
    </div>
  </section>
</BaseLayout>
